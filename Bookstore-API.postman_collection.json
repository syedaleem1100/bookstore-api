{
  "info": {
    "name": "Online Bookstore Management API",
    "description": "Postman collection for CS 224 Assignment 02 - Online Bookstore Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "bookId",
      "value": "PASTE_A_VALID_BOOK_ID_HERE"
    }
  ],
  "item": [
    {
      "name": "Get All Books",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books"]
        }
      }
    },
    {
      "name": "Get Books with Search and Pagination",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/books?author=Rowling&genre=Fantasy&page=1&limit=5",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books"],
          "query": [
            { "key": "author", "value": "Rowling" },
            { "key": "genre", "value": "Fantasy" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "5" }
          ]
        }
      }
    },
    {
      "name": "Get Single Book by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "{{bookId}}"]
        }
      }
    },
    {
      "name": "Add a New Book",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Harry Potter and the Sorcerer's Stone\",\n  \"author\": \"J.K. Rowling\",\n  \"genre\": \"Fantasy\",\n  \"price\": 14.99,\n  \"publishedDate\": \"1997-06-26\",\n  \"inStock\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/books",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books"]
        }
      }
    },
    {
      "name": "Update a Book by ID",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 12.99,\n  \"inStock\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "{{bookId}}"]
        }
      }
    },
    {
      "name": "Delete a Book by ID",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/books/{{bookId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "books", "{{bookId}}"]
        }
      }
    },
    {
      "name": "Invalid Route (404 test)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/nonexistent",
          "host": ["{{baseUrl}}"],
          "path": ["api", "nonexistent"]
        }
      }
    }
  ]
}
